# .gitignore - Python + Docker infrastructure defaults

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.env
.venv/
venv/
ENV/
env/
venv.bak/

# Python tooling caches
.pytest_cache/
.mypy_cache/
.pyre/
.pytype/
.cache/
.coverage
coverage.xml
htmlcov/

# Test / coverage outputs
*.cover
nosetests.xml
test-reports/

# Django / Flask / local settings
local_settings.py
*.sqlite
db.sqlite3

# Logs and runtime files
*.log
logs/
*.pid

# Docker-related
.env
.env.*                # local env overrides with secrets
docker-compose.override.yml
docker-compose.*.local.yml
docker-compose.*.override.yml
docker-compose.override.yml
docker-*.log
docker-compose.override.log

# Docker build context leftovers / compose volumes
tmp/
volumes/
*.tar
*.tar.gz

# Certificates, keys, secrets
*.pem
*.key
*.crt
secrets/
certs/

# IDEs and editors
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Jupyter
.ipynb_checkpoints/

# Misc
*.swp
*~ 