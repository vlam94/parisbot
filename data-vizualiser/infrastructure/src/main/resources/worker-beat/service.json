{
  "name": "superset-worker-beat",
  "version": "5.3.0",
  "type": "scheduler",
  "engine": "celery-beat",
  "image": "apache/superset:6.0-python3.11",
  "description": "Celery Beat scheduler for Superset report scheduling",
  "ports": [],
  "environment": {
    "SUPERSET_CONFIG_PATH": "/app/pythonpath/superset_config.py",
    "SUPERSET_DATABASE_URI": "postgresql://superset:${SUPERSET_DB_PASSWORD}@superset-database:5433/superset",
    "REDIS_CELERY_DB": "2",
    "REDIS_RESULTS_DB": "3"
  },
  "volumes": [
    "superset_logs:/var/log/superset"
  ],
  "resources": {
    "limits": {
      "cpus": "0.1",
      "memory": "200MB"
    },
    "reservations": {
      "cpus": "0.05",
      "memory": "100MB"
    }
  },
  "healthcheck": {
    "test": ["CMD-SHELL", "ps aux | grep 'celery.*beat' | grep -v grep || exit 1"],
    "interval": "30s",
    "timeout": "10s",
    "retries": 3
  },
  "network": "parisbot-net",
  "depends_on": ["superset-database", "superset-cache"]
}
