{
  "name": "superset-database",
  "version": "18.0.0",
  "type": "database",
  "engine": "postgresql",
  "image": "postgres:18-alpine",
  "description": "PostgreSQL metadata database for Superset",
  "ports": [5433],
  "environment": {
    "POSTGRES_USER": "superset",
    "POSTGRES_PASSWORD": "${SUPERSET_DB_PASSWORD}",
    "POSTGRES_DB": "superset",
    "POSTGRES_INITDB_ARGS": "-c shared_buffers=256MB"
  },
  "volumes": [
    "superset_db_data:/var/lib/postgresql/data"
  ],
  "resources": {
    "limits": {
      "cpus": "0.3",
      "memory": "512MB"
    },
    "reservations": {
      "cpus": "0.15",
      "memory": "256MB"
    }
  },
  "healthcheck": {
    "test": ["CMD-SHELL", "pg_isready -U superset -d superset"],
    "interval": "10s",
    "timeout": "5s",
    "retries": 3
  },
  "network": "parisbot-net",
  "depends_on": []
}
