{
  "name": "superset-cache",
  "version": "7.0.0",
  "type": "cache",
  "engine": "redis",
  "image": "redis:7-alpine",
  "description": "Redis cache for Superset results and sessions",
  "ports": [6380],
  "environment": {},
  "volumes": [
    "superset_redis_data:/data"
  ],
  "resources": {
    "limits": {
      "cpus": "0.2",
      "memory": "300MB"
    },
    "reservations": {
      "cpus": "0.1",
      "memory": "150MB"
    }
  },
  "healthcheck": {
    "test": ["CMD", "redis-cli", "ping"],
    "interval": "10s",
    "timeout": "5s",
    "retries": 3
  },
  "network": "parisbot-net",
  "depends_on": []
}
