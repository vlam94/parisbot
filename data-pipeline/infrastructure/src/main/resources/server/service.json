{
  "name": "airflow-server",
  "version": "3.1.0",
  "type": "application",
  "engine": "airflow",
  "image": "apache/airflow:3.1-python3.11",
  "description": "Apache Airflow webserver for DAG orchestration",
  "ports": [8080],
  "environment": {
    "AIRFLOW__CORE__DAGS_FOLDER": "/opt/airflow/dags",
    "AIRFLOW__CORE__EXECUTOR": "CeleryExecutor",
    "AIRFLOW__DATABASE__SQL_ALCHEMY_CONN": "postgresql://airflow:${AIRFLOW_DB_PASSWORD}@airflow-database:5432/airflow",
    "AIRFLOW__CELERY__BROKER_URL": "redis://airflow-messenger:6379/0",
    "AIRFLOW__CELERY__RESULT_BACKEND": "redis://airflow-messenger:6379/1",
    "AIRFLOW__CORE__LOAD_EXAMPLES": "False"
  },
  "volumes": [
    "airflow_logs:/opt/airflow/logs",
    "./../../python/dags:/opt/airflow/dags:ro"
  ],
  "resources": {
    "limits": {
      "cpus": "0.8",
      "memory": "1.2G"
    },
    "reservations": {
      "cpus": "0.4",
      "memory": "600MB"
    }
  },
  "healthcheck": {
    "test": ["CMD", "curl", "-f", "http://localhost:8080/health"],
    "interval": "30s",
    "timeout": "10s",
    "retries": 3
  },
  "network": "parisbot-net",
  "depends_on": ["airflow-database", "airflow-messenger"],
  "ports_mapping": {
    "8080": "8080"
  }
}
