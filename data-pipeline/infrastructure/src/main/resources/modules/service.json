{
  "name": "airflow",
  "version": "1.0.0",
  "type": "scheduler",
  "engine": "airflow",
  "image": "apache/airflow:2.8.0-python3.11",
  "container_name": "dataops-airflow",
  "description": "Apache Airflow 3.1 data pipeline orchestrator",
  "ports": {
    "internal": 8080,
    "external": 8080
  },
  "environment": {
    "AIRFLOW__CORE__DAGS_FOLDER": "/opt/airflow/dags",
    "AIRFLOW__CORE__EXECUTOR": "CeleryExecutor",
    "AIRFLOW__DATABASE__SQL_ALCHEMY_CONN": "postgresql://airflow:airflow_pass@airflow-db:5432/airflow",
    "AIRFLOW__CELERY__BROKER_URL": "redis://redis:6379/0",
    "AIRFLOW__CELERY__RESULT_BACKEND": "redis://redis:6379/1"
  },
  "volumes": {
    "dags": "/opt/airflow/dags",
    "plugins": "/opt/airflow/plugins",
    "logs": "/opt/airflow/logs"
  },
  "resources": {
    "cpu_limit": "1.5",
    "memory_limit": "2G",
    "cpu_reservation": "0.75",
    "memory_reservation": "1G"
  },
  "healthcheck": {
    "test": "curl -f http://localhost:8080/health || exit 1",
    "interval": 30,
    "timeout": 10,
    "retries": 3
  },
  "depends_on": {
    "airflow-db": "service_healthy",
    "redis": "service_healthy"
  },
  "network": {
    "name": "dataops-net",
    "driver": "bridge"
  },
  "restart_policy": "unless-stopped"
}
