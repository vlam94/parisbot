{
  "name": "airflow-scheduler",
  "version": "5.3.0",
  "type": "scheduler",
  "engine": "celery-beat",
  "image": "apache/airflow:3.1.8rc2-python3.11",
  "description": "Celery Beat scheduler for periodic Airflow task execution",
  "ports": [],
  "environment": {
    "AIRFLOW__CORE__EXECUTOR": "CeleryExecutor",
    "AIRFLOW__DATABASE__SQL_ALCHEMY_CONN": "postgresql://airflow:${AIRFLOW_DB_PASSWORD}@airflow-database:5432/airflow",
    "AIRFLOW__CELERY__BROKER_URL": "redis://airflow-messenger:6379/0",
    "AIRFLOW__CELERY__RESULT_BACKEND": "redis://airflow-messenger:6379/1"
  },
  "volumes": [
    "airflow_logs:/opt/airflow/logs"
  ],
  "resources": {
    "limits": {
      "cpus": "0.2",
      "memory": "300MB"
    },
    "reservations": {
      "cpus": "0.1",
      "memory": "150MB"
    }
  },
  "healthcheck": {
    "test": ["CMD-SHELL", "ps aux | grep 'celery.*beat' | grep -v grep || exit 1"],
    "interval": "30s",
    "timeout": "10s",
    "retries": 3
  },
  "network": "parisbot-net",
  "depends_on": ["airflow-database", "airflow-messenger"]
}
